rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // HELPERS CONCEITUAIS
    // ==========================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isActiveUser() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().status == 'active';
    }
    
    function isAdmin() {
      return getUserData().role == 'admin';
    }
    
    function isHR() {
      return getUserData().role == 'hr';
    }
    
    function isManager() {
      return getUserData().role == 'manager';
    }
    
    function isSupervisor() {
      return getUserData().role == 'supervisor';
    }
    
    function isViewer() {
      return getUserData().role == 'viewer';
    }
    
    function isUserRole() {
      return getUserData().role == 'user';
    }

    function isOwnDocument(uid) {
      return request.auth.uid == uid;
    }

    function belongsToCompany(companyId) {
      return getUserData().company_id == companyId;
    }

    function hasCellAccess(cellId) {
      return isAdmin() || 
             getUserData().can_view_all_cells == true || 
             (cellId in getUserData().allowed_cell_ids);
    }

    function hasTeamAccess(teamId) {
      return isAdmin() || 
             getUserData().can_view_all_teams == true || 
             (teamId in getUserData().allowed_team_ids);
    }

    // ==========================================
    // REGRAS DE ACESSO POR COLEÇÃO
    // ==========================================

    // allowed_emails
    match /allowed_emails/{emailId} {
      allow get: if true;
      allow list: if isActiveUser() && (isAdmin() || isHR() || isManager());
      allow write: if isActiveUser() && (isAdmin() || isHR());
    }

    // users
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwnDocument(userId) || (isActiveUser() && (isAdmin() || isHR() || isManager())));
      
      // Permitir criação se o usuário estiver criando seu próprio perfil e os dados baterem com o e-mail autorizado
      allow create: if isSignedIn() && isOwnDocument(userId) && 
        exists(/databases/$(database)/documents/allowed_emails/$(request.resource.data.normalized_email)) &&
        request.resource.data.role == get(/databases/$(database)/documents/allowed_emails/$(request.resource.data.normalized_email)).data.role &&
        request.resource.data.status == 'active';
        
      // O próprio usuário pode atualizar seu login/perfil básico, mas não pode alterar permissões ou papel.
      allow update: if isActiveUser() && (
        (isOwnDocument(userId) && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.status == resource.data.status && 
         request.resource.data.company_id == resource.data.company_id &&
         (!('allowed_team_ids' in request.resource.data) || request.resource.data.allowed_team_ids == resource.data.allowed_team_ids) &&
         (!('allowed_cell_ids' in request.resource.data) || request.resource.data.allowed_cell_ids == resource.data.allowed_cell_ids) &&
         (!('allowed_employee_ids' in request.resource.data) || request.resource.data.allowed_employee_ids == resource.data.allowed_employee_ids) &&
         (!('can_view_all_company' in request.resource.data) || request.resource.data.can_view_all_company == resource.data.can_view_all_company) &&
         (!('can_view_all_business_unit' in request.resource.data) || request.resource.data.can_view_all_business_unit == resource.data.can_view_all_business_unit) &&
         (!('can_view_all_cells' in request.resource.data) || request.resource.data.can_view_all_cells == resource.data.can_view_all_cells) &&
         (!('can_view_all_teams' in request.resource.data) || request.resource.data.can_view_all_teams == resource.data.can_view_all_teams) &&
         (!('can_approve' in request.resource.data) || request.resource.data.can_approve == resource.data.can_approve) &&
         (!('approval_level' in request.resource.data) || request.resource.data.approval_level == resource.data.approval_level)
        ) || 
        isAdmin() || 
        (isHR() && request.resource.data.role != 'admin')
      );
      allow delete: if isActiveUser() && isAdmin();
    }

    // companies
    match /companies/{companyId} {
      allow read: if isActiveUser() && (isAdmin() || belongsToCompany(companyId));
      allow write: if isActiveUser() && isAdmin();
    }

    // business_units
    match /business_units/{unitId} {
      allow read: if isActiveUser() && (isAdmin() || belongsToCompany(resource.data.company_id));
      allow write: if isActiveUser() && isAdmin();
    }

    // production_cells
    match /production_cells/{cellId} {
      allow read: if isActiveUser() && (isAdmin() || belongsToCompany(resource.data.company_id));
      allow write: if isActiveUser() && (isAdmin() || isHR() || isManager() || isSupervisor());
    }

    // teams
    match /teams/{teamId} {
      allow read: if isActiveUser() && (
        isAdmin() || isHR() || isManager() || belongsToCompany(resource.data.company_id)
      );
      allow write: if isActiveUser() && (isAdmin() || isHR() || isManager() || isSupervisor());
    }

    // employees
    match /employees/{employeeId} {
      allow read: if isActiveUser() && (
        isAdmin() || isHR() || isManager() || isViewer() ||
        (isSupervisor() && (
          resource.data.owner_supervisor_id == request.auth.uid ||
          (resource.data.team_id in getUserData().allowed_team_ids) ||
          (resource.data.id in getUserData().allowed_employee_ids)
        )) ||
        (isUserRole() && resource.data.email == request.auth.token.email)
      );
      allow write: if isActiveUser() && (
        isAdmin() || isHR() ||
        (isSupervisor() && (
          // Impede supervisor de gravar colaborador fora da equipe dele
          request.resource.data.owner_supervisor_id == request.auth.uid ||
          (request.resource.data.team_id in getUserData().allowed_team_ids)
        ))
      );
    }

    // vacation_requests
    match /vacation_requests/{requestId} {
      allow read: if isActiveUser() && (
        isAdmin() || isHR() || isManager() || isViewer() ||
        (isSupervisor() && (
          resource.data.owner_supervisor_id == request.auth.uid ||
          (resource.data.team_id in getUserData().allowed_team_ids) ||
          (resource.data.employee_id in getUserData().allowed_employee_ids)
        )) ||
        (isUserRole() && resource.data.requester_user_id == request.auth.uid)
      );
      allow write: if isActiveUser() && (
        isAdmin() || isHR() ||
        (isSupervisor() && (
          request.resource.data.owner_supervisor_id == request.auth.uid ||
          (request.resource.data.team_id in getUserData().allowed_team_ids)
        )) ||
        (isUserRole() && request.resource.data.requester_user_id == request.auth.uid)
      );
    }

    // absence_records
    match /absence_records/{recordId} {
      allow read: if isActiveUser() && (
        isAdmin() || isHR() || isManager() || isViewer() ||
        (isSupervisor() && (
          resource.data.owner_supervisor_id == request.auth.uid ||
          (resource.data.team_id in getUserData().allowed_team_ids) ||
          (resource.data.employee_id in getUserData().allowed_employee_ids)
        ))
      );
      allow write: if isActiveUser() && (
        isAdmin() || isHR() ||
        (isSupervisor() && (
          request.resource.data.owner_supervisor_id == request.auth.uid ||
          (request.resource.data.team_id in getUserData().allowed_team_ids)
        ))
      );
    }

    // capacity_snapshots
    match /capacity_snapshots/{snapshotId} {
      allow read: if isActiveUser() && (
        isAdmin() || isHR() || isManager() || isViewer() ||
        (isSupervisor() && hasCellAccess(resource.data.cell_id))
      );
      allow write: if isActiveUser() && (isAdmin() || isHR() || isManager() || isSupervisor());
    }

    // alerts
    match /alerts/{alertId} {
      allow read: if isActiveUser() && (
        isAdmin() || isHR() || isManager() || isViewer() ||
        (isSupervisor() && hasCellAccess(resource.data.cell_id))
      );
      allow write: if isActiveUser();
    }

    // notifications
    match /notifications/{notificationId} {
      allow read: if isActiveUser() && (
        resource.data.recipient_user_id == request.auth.uid || 
        resource.data.recipient_role == getUserData().role ||
        isAdmin()
      );
      allow write: if isActiveUser();
    }

    // blocked_periods
    match /blocked_periods/{periodId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser() && (isAdmin() || isHR() || isManager());
    }

    // system_logs
    match /system_logs/{logId} {
      allow read: if isActiveUser() && (isAdmin() || isHR() || isManager());
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // settings
    match /settings/{settingsId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser() && isAdmin();
    }
  }
}